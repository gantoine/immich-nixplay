<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- leanback-preference 1.1.0-rc01 declares minSdk 21 but is only used for its Compat
         preference fragments (no real API-21 dependency); allow it on this minSdk-19 build. -->
    <uses-sdk tools:overrideLibrary="androidx.leanback.preference" />

    <!-- Keep the display awake while showing photos (Nixplay frame) -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Access internet-based media -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- For writing to home screen channels -->
    <uses-permission android:name="com.android.providers.tv.permission.WRITE_EPG_DATA" />

    <uses-permission android:name="com.google.android.gms.permission.AD_ID" tools:node="remove"/>

    <!-- Touch screen is not required -->
    <uses-feature
        android:name="android.hardware.touchscreen"
        android:required="false" />

    <!-- This is an Android TV app only (not intended for mobile) -->
    <uses-feature
        android:name="android.software.leanback"
        android:required="true" />

    <application
        android:name="nl.giejay.android.tv.immich.ImmichApplication"
        android:allowBackup="true"
        android:fullBackupContent="true"
        android:icon="@drawable/icon"
        android:usesCleartextTraffic="true"
        android:largeHeap="true"
        android:hardwareAccelerated="true"
        android:banner="@mipmap/icon_banner_v2"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <service
            android:name="nl.giejay.android.tv.immich.screensaver.ScreenSaverService"
            android:exported="true"
            android:label="Immich"
            android:permission="android.permission.BIND_DREAM_SERVICE">
            <intent-filter>
                <category android:name="android.intent.category.DEFAULT" />
                <action android:name="android.service.dreams.DreamService" />
            </intent-filter>

            <!-- Point to additional information for this dream (optional) -->
            <meta-data
                android:name="android.service.dream"
                android:resource="@xml/screensaver" />
        </service>

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:configChanges="keyboard|keyboardHidden|navigation">

            <!-- Used as the main entry point from the leanback launcher.
                 HOME + DEFAULT categories let the app act as the device's home/launcher
                 app so the Nixplay frame can boot straight into it. -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
                <category android:name="android.intent.category.LAUNCHER" />
                <category android:name="android.intent.category.HOME" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>

        </activity>

        <!-- BroadcastReceiver for setting up the home screen channel -->
<!--        <receiver-->
<!--            android:name="nl.giejay.android.tv.immich.homescreenchannels.HomeScreenChannelReceiver"-->
<!--            android:exported="true">-->
<!--            <intent-filter>-->
<!--                <action android:name="android.media.tv.action.INITIALIZE_PROGRAMS" />-->
<!--                <category android:name="android.intent.category.DEFAULT" />-->
<!--            </intent-filter>-->
<!--        </receiver>-->

    </application>

</manifest>